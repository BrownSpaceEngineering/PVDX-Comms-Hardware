	(text "DESIGN RULES FLAGGED IN DATASHEET:\nPlace decoupling capacitors (100 nF) close to pins\nEVDD and DEVDD should have the same voltage\nAVSS and DVSS are analog and digital grounds. They should be kept separate except at a single point.\nCrystal lines must be routed as short as possible and not in proximity to digital I/O signals.\nAny lines tagged P/N are differential pairs"
		(exclude_from_sim no)
		(at 32.258 142.24 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "615878ab-bfc5-4eb3-b88f-f4eb763fa857")
	)
